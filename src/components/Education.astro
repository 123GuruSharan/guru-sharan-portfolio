---
// Education timeline — matches Experience layout and styling
---

<section
  id="education"
  class="education-section scroll-mt-[100px] py-20"
  style="background: radial-gradient(circle at center, #0f172a, #020617);"
>
  <div class="container mx-auto px-6">
    <h2 class="education-title text-center mb-16">
      <span>Education</span>
    </h2>

    <div class="edu-timeline relative max-w-7xl mx-auto">
      <div
        class="edu-timeline-line absolute left-1/2 transform -translate-x-1/2 w-1 bg-gradient-to-b from-blue-400 to-blue-600 h-full rounded-full"
      >
      </div>

      <!-- 1 — Left: B.Tech -->
      <div class="edu-timeline-item edu-timeline-item-left relative mb-12">
        <div class="edu-timeline-date">
          <div
            class="bg-white/5 backdrop-blur-sm border border-white/10 px-4 py-2 rounded-full flex items-center gap-2 text-slate-300 text-sm font-medium whitespace-nowrap"
          >
            <svg
              class="w-4 h-4 text-blue-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
            Aug 2023 – Present
          </div>
        </div>
        <div
          class="edu-timeline-node absolute left-4 md:left-1/2 md:-translate-x-1/2 top-0 w-12 h-12 rounded-xl bg-[#050505] border border-white/15 flex items-center justify-center z-10"
        >
          <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6L21 9 12 3zm0 2.18l5.91 3.27-2.55 1.4L12 8.77 8.64 9.85 12 5.45zm-6 5.73l4-2.19V16.9l-4 2.17V11.91zm12 7.06v-6.17l-4 2.17v6.17l4-2.17z"
            ></path>
          </svg>
        </div>
        <div class="flex items-center">
          <div
            class="edu-timeline-content w-full md:w-[62%] md:pr-12 text-left mr-16"
          >
            <div
              class="edu-timeline-card bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-xl p-8 md:p-10 shadow-lg"
            >
              <h3
                class="text-xl md:text-2xl font-bold text-Text-light mb-2 leading-snug"
              >
                B.Tech – Computer Science & Engineering
              </h3>
              <h4 class="text-base md:text-lg text-blue-400 font-medium mb-3">
                Lovely Professional University, Punjab
              </h4>
              <p class="text-sm md:text-[15px] text-Text-light/85">
                CGPA: 7.25
              </p>
            </div>
          </div>
          <div class="hidden md:block w-[38%]"></div>
        </div>
      </div>

      <!-- 2 — Right: Intermediate -->
      <div class="edu-timeline-item edu-timeline-item-right relative mb-12">
        <div class="edu-timeline-date">
          <div
            class="bg-white/5 backdrop-blur-sm border border-white/10 px-4 py-2 rounded-full flex items-center gap-2 text-slate-300 text-sm font-medium whitespace-nowrap"
          >
            <svg
              class="w-4 h-4 text-blue-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
            Apr 2021 – Mar 2023
          </div>
        </div>
        <div
          class="edu-timeline-node absolute left-4 md:left-1/2 md:-translate-x-1/2 top-0 w-12 h-12 rounded-xl bg-[#050505] border border-white/15 flex items-center justify-center z-10"
        >
          <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6L21 9 12 3zm0 2.18l5.91 3.27-2.55 1.4L12 8.77 8.64 9.85 12 5.45zm-6 5.73l4-2.19V16.9l-4 2.17V11.91zm12 7.06v-6.17l-4 2.17v6.17l4-2.17z"
            ></path>
          </svg>
        </div>
        <div class="flex items-center">
          <div class="hidden md:block w-[38%]"></div>
          <div class="edu-timeline-content w-full md:w-[62%] md:pl-12 ml-16">
            <div
              class="edu-timeline-card edu-timeline-card-right bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-xl p-8 md:p-10 shadow-lg"
            >
              <h3
                class="text-xl md:text-2xl font-bold text-Text-light mb-2 leading-snug"
              >
                Intermediate (Class 12)
              </h3>
              <h4 class="text-base md:text-lg text-blue-400 font-medium mb-3">
                De Nobili School, Maithon
              </h4>
              <p class="text-sm md:text-[15px] text-Text-light/85">
                Percentage: 70%
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- 3 — Left: Matriculation -->
      <div class="edu-timeline-item edu-timeline-item-left relative mb-12">
        <div class="edu-timeline-date">
          <div
            class="bg-white/5 backdrop-blur-sm border border-white/10 px-4 py-2 rounded-full flex items-center gap-2 text-slate-300 text-sm font-medium whitespace-nowrap"
          >
            <svg
              class="w-4 h-4 text-blue-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
            Apr 2019 – Mar 2021
          </div>
        </div>
        <div
          class="edu-timeline-node absolute left-4 md:left-1/2 md:-translate-x-1/2 top-0 w-12 h-12 rounded-xl bg-[#050505] border border-white/15 flex items-center justify-center z-10"
        >
          <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6L21 9 12 3zm0 2.18l5.91 3.27-2.55 1.4L12 8.77 8.64 9.85 12 5.45zm-6 5.73l4-2.19V16.9l-4 2.17V11.91zm12 7.06v-6.17l-4 2.17v6.17l4-2.17z"
            ></path>
          </svg>
        </div>
        <div class="flex items-center">
          <div
            class="edu-timeline-content w-full md:w-[62%] md:pr-12 text-left mr-16"
          >
            <div
              class="edu-timeline-card bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-xl p-8 md:p-10 shadow-lg"
            >
              <h3
                class="text-xl md:text-2xl font-bold text-Text-light mb-2 leading-snug"
              >
                Matriculation (Class 10)
              </h3>
              <h4 class="text-base md:text-lg text-blue-400 font-medium mb-3">
                De Nobili School, Maithon
              </h4>
              <p class="text-sm md:text-[15px] text-Text-light/85">
                Percentage: 76%
              </p>
            </div>
          </div>
          <div class="hidden md:block w-[38%]"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .education-title {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 64px;
  }

  .education-title::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1.5px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(251, 146, 60, 0.65),
      transparent
    );
    transform: translateY(-50%);
    z-index: 0;
  }

  .education-title span {
    position: relative;
    z-index: 1;
    display: inline-block;
    padding: 14px 42px;
    border-radius: 999px;
    background: #050505;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 0 18px rgba(2, 6, 23, 0.45),
      0 0 26px rgba(251, 146, 60, 0.24);
    color: #ffffff;
    font-weight: 800;
    font-size: clamp(1.6rem, 3vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: 0.01em;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.18);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      text-shadow 0.35s ease;
  }

  .education-title span::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    z-index: -1;
    background: radial-gradient(
      circle,
      rgba(251, 146, 60, 0.28) 0%,
      rgba(251, 146, 60, 0) 70%
    );
    filter: blur(8px);
    pointer-events: none;
    opacity: 0.7;
    transition:
      opacity 0.35s ease,
      filter 0.35s ease;
  }

  .education-title:hover span {
    transform: translateY(-2px) scale(1.01);
    box-shadow:
      0 0 18px rgba(2, 6, 23, 0.45),
      0 0 36px rgba(251, 146, 60, 0.36);
    text-shadow: 0 0 14px rgba(255, 255, 255, 0.3);
  }

  .education-title:hover span::after {
    opacity: 1;
    filter: blur(11px);
  }

  .edu-timeline-line {
    background: linear-gradient(to bottom, #3b82f6, #60a5fa);
    box-shadow: 0 0 10px rgba(59, 130, 246, 0.4);
    width: 2px;
  }

  .edu-timeline-item {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: auto;
    padding-top: 72px;
  }

  .edu-timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .edu-timeline-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
    cursor: default;
    max-width: 1060px;
    width: 100%;
  }

  .edu-timeline-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow:
      0 0 25px rgba(96, 165, 250, 0.2),
      0 0 28px rgba(251, 146, 60, 0.28),
      0 14px 34px rgba(0, 0, 0, 0.45);
    border-color: rgba(251, 146, 60, 0.45);
  }

  .edu-timeline-item-right .edu-timeline-card-right {
    margin-left: 56px;
  }

  .edu-timeline-date {
    position: absolute;
    top: 50%;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 14px;
    color: #94a3b8;
    z-index: 20;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    transform: translateY(-50%);
  }

  .edu-timeline-item-left .edu-timeline-date {
    left: calc(50% + 48px);
  }

  .edu-timeline-item-right .edu-timeline-date {
    left: auto;
    right: calc(50% + 48px);
  }

  .edu-timeline-date::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background: #3b82f6;
    border-radius: 50%;
    box-shadow: 0 0 10px #3b82f6;
    z-index: -1;
  }

  .edu-timeline-item:hover .edu-timeline-date {
    transform: translateY(calc(-50% - 2px));
    box-shadow: 0 0 18px rgba(59, 130, 246, 0.22);
  }

  @media (min-width: 769px) {
    .edu-timeline-item-left .edu-timeline-content,
    .edu-timeline-item-right .edu-timeline-content {
      width: calc(50% - 76px) !important;
      max-width: calc(50% - 76px);
    }

    .edu-timeline-item-left .edu-timeline-content {
      margin-right: 76px !important;
      padding-right: 0 !important;
    }

    .edu-timeline-item-right .edu-timeline-content {
      margin-left: 76px !important;
      padding-left: 0 !important;
    }
  }

  @media (max-width: 768px) {
    .education-title {
      margin-bottom: 48px;
    }

    .education-title span {
      padding: 12px 26px;
      font-size: clamp(1.35rem, 5.5vw, 1.85rem);
    }

    .edu-timeline-line {
      left: 16px;
      width: 4px;
      box-shadow: 0 0 10px rgba(59, 130, 246, 0.4);
    }

    .edu-timeline-card {
      margin-left: 40px;
      width: calc(100% - 60px);
      transform: none;
      max-width: none;
      padding: 28px !important;
    }

    .edu-timeline-card:hover {
      transform: none;
      box-shadow:
        0 0 22px rgba(96, 165, 250, 0.25),
        0 0 20px rgba(251, 146, 60, 0.2);
    }

    .edu-timeline-item-right .edu-timeline-card-right {
      margin-left: 40px;
    }

    .edu-timeline-date {
      left: 16px;
      right: auto;
      transform: translateX(0);
      top: 10px;
    }

    .edu-timeline-date::before {
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>

<script>
  function initEducationTimeline() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px",
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add("visible");
          }, index * 200);
        }
      });
    }, observerOptions);

    document
      .querySelectorAll("#education .edu-timeline-item")
      .forEach((item) => observer.observe(item));
  }

  document.addEventListener("DOMContentLoaded", initEducationTimeline);
  document.addEventListener("astro:page-load", initEducationTimeline);
</script>
