---
// Experience component for portfolio
---

<!-- // using inline SVGs for icons to avoid external runtime imports -->


<section id="experience" class="experience-section py-20">
  <div class="container mx-auto px-6">
    <h2 class="journey-title text-center mb-16">
      <span>Professional Journey</span>
    </h2>

    <div class="timeline relative max-w-7xl mx-auto">
      <!-- Timeline Line -->
      <div class="timeline-line absolute left-1/2 transform -translate-x-1/2 w-1 bg-gradient-to-b from-blue-400 to-blue-600 h-full rounded-full"></div>

      <!-- Experience Item 1 - Left -->
      <div class="timeline-item timeline-item-left relative mb-12">
        <div class="timeline-date">
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 px-4 py-2 rounded-full flex items-center gap-2 text-slate-300 text-sm font-medium whitespace-nowrap">
            <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            Jan 2026 – Mar 2026
          </div>
        </div>
        <div class="timeline-node absolute left-4 md:left-1/2 md:-translate-x-1/2 top-0 w-12 h-12 rounded-xl bg-[#050505] border border-white/15 flex items-center justify-center z-10">
          <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 7l-8-4-8 4v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7z"/>
          </svg>
        </div>
        <div class="flex items-center">
          <div class="timeline-content w-full md:w-[62%] md:pr-12 text-left mr-16">
            <div class="timeline-card bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-xl p-10 shadow-lg">
              <h3 class="text-2xl font-bold text-Text-light mb-2">Full Stack Developer Intern</h3>
              <h4 class="text-lg text-blue-400 font-medium mb-4">Happieloop Technologies</h4>
              <ul class="text-Text-light/80 text-sm lg:text-[15px] space-y-2">
                <li class="flex items-start">
                  Developed responsive web applications using HTML, CSS, and JavaScript
                </li>
                <li class="flex items-start">
                  Built scalable backend APIs using Node.js and Express.js
                </li>
                <li class="flex items-start">
                  Designed and managed MongoDB databases for real-time applications
                </li>
                <li class="flex items-start">
                  Integrated REST APIs and implemented real-time features using WebSocket
                </li>
                <li class="flex items-start">
                  Improved application performance, debugging, and reliability
                </li>
              </ul>
            </div>
          </div>
          <div class="hidden md:block w-[38%]"></div>
        </div>
      </div>

      <!-- Experience Item 2 - Right -->
      <div class="timeline-item timeline-item-right relative mb-12">
        <div class="timeline-date">
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 px-4 py-2 rounded-full flex items-center gap-2 text-slate-300 text-sm font-medium whitespace-nowrap">
            <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            Feb 2026 - Present
          </div>
        </div>
        <div class="timeline-node absolute left-4 md:left-1/2 md:-translate-x-1/2 top-0 w-12 h-12 rounded-xl bg-[#050505] border border-white/15 flex items-center justify-center z-10">
          <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 7l-8-4-8 4v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7z"/>
          </svg>
        </div>
        <div class="flex items-center">
          <div class="hidden md:block w-[38%]"></div>
          <div class="timeline-content w-full md:w-[62%] md:pl-12 ml-16">
            <div class="timeline-card timeline-card-right bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-xl p-10 shadow-lg">
              <h3 class="text-2xl font-bold text-Text-light mb-2">Software Development Intern</h3>
              <h4 class="text-lg text-blue-400 font-medium mb-4">Infosys Springboard</h4>
              <ul class="text-Text-light/80 text-sm lg:text-[15px] space-y-3">
                <li class="flex items-start">
                  Developed an automated regression testing web application to streamline testing workflows
                </li>
                <li class="flex items-start">
                  Designed test automation logic to significantly reduce manual testing effort
                </li>
                <li class="flex items-start">
                  Built backend services and integrated automated testing pipelines
                </li>
                <li class="flex items-start">
                  Focused on improving testing speed, accuracy, and reliability
                </li>
                <li class="flex items-start">
                  Implemented efficient debugging and error-handling mechanisms
                </li>
                <!-- <li class="flex items-start">
                  Worked with modern web technologies to build scalable and maintainable solutions
                </li> -->
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience-section {
    background: transparent;
  }

  .journey-title {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 64px;
  }

  .journey-title::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1.5px;
    background: linear-gradient(to right, transparent, rgba(251,146,60,0.65), transparent);
    transform: translateY(-50%);
    z-index: 0;
  }

  .journey-title span {
    position: relative;
    z-index: 1;
    display: inline-block;
    padding: 14px 42px;
    border-radius: 999px;
    background: #050505;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow:
      0 0 18px rgba(2, 6, 23, 0.45),
      0 0 26px rgba(251, 146, 60, 0.24);
    color: #ffffff;
    font-weight: 800;
    font-size: clamp(1.8rem, 3.2vw, 3rem);
    line-height: 1.1;
    letter-spacing: 0.01em;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.18);
    transition: transform 0.35s ease, box-shadow 0.35s ease, text-shadow 0.35s ease;
  }

  .journey-title span::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    z-index: -1;
    background: radial-gradient(circle, rgba(251,146,60,0.28) 0%, rgba(251,146,60,0) 70%);
    filter: blur(8px);
    pointer-events: none;
    opacity: 0.7;
    transition: opacity 0.35s ease, filter 0.35s ease;
  }

  .journey-title:hover span {
    transform: translateY(-2px) scale(1.01);
    box-shadow:
      0 0 18px rgba(2, 6, 23, 0.45),
      0 0 36px rgba(251, 146, 60, 0.36);
    text-shadow: 0 0 14px rgba(255, 255, 255, 0.3);
  }

  .journey-title:hover span::after {
    opacity: 1;
    filter: blur(11px);
  }

  .timeline-line {
    background: linear-gradient(to bottom, #3b82f6, #60a5fa);
    box-shadow: 0 0 10px rgba(59,130,246,0.4);
    width: 2px;
  }

  .timeline-item {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: auto;
    padding-top: 72px;
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    max-width: 2060px;
    width: 120%;
    padding: 40px;
    margin-left: -10%;
    margin-right: 30%;
  }

  .timeline-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow:
      0 0 25px rgba(96, 165, 250, 0.2),
      0 0 28px rgba(251, 146, 60, 0.28),
      0 14px 34px rgba(0, 0, 0, 0.45);
    border-color: rgba(251, 146, 60, 0.45);
  }

  /* Bottom (right) card only: prevent center-line overlap */
  .timeline-item-right .timeline-card-right {
    margin-left: 56px;
  }

  .timeline-date {
    position: absolute;
    top: 50%;
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    font-size: 14px;
    color: #94a3b8;
    z-index: 20;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    transform: translateY(-50%);
  }

  /* Place date badge opposite to the card side on desktop */
  .timeline-item-left .timeline-date {
    left: calc(50% + 48px);
  }

  .timeline-item-right .timeline-date {
    left: auto;
    right: calc(50% + 48px);
  }

  .timeline-date::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background: #3b82f6;
    border-radius: 50%;
    box-shadow: 0 0 10px #3b82f6;
    z-index: -1;
  }

  .timeline-item:hover .timeline-date {
    transform: translateY(calc(-50% - 2px));
    box-shadow: 0 0 18px rgba(59,130,246,0.22);
  }

  @media (min-width: 769px) {
    /* Keep cards wide but preserve a fixed center lane */
    .timeline-item-left .timeline-content,
    .timeline-item-right .timeline-content {
      width: calc(50% - 76px) !important;
      max-width: calc(50% - 76px);
    }

    .timeline-item-left .timeline-content {
      margin-right: 76px !important;
      padding-right: 0 !important;
    }

    .timeline-item-right .timeline-content {
      margin-left: 76px !important;
      padding-left: 0 !important;
    }
  }

  .timeline-card h3 {
    font-size: 22px;
    color: #ffffff;
  }

  .timeline-card h4 {
    font-size: 18px;
    color: #3b82f6;
  }

  .timeline-card ul {
    list-style: none;
    padding-left: 0;
  }

  .timeline-card ul li {
    line-height: 1.6;
    color: #cbd5e1;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .timeline-card ul li::before {
    content: "›";
    color: #3b82f6;
    font-weight: bold;
  }

  .timeline-card ul li:hover {
    transform: translateX(3px);
    color: #ffffff;
  }

  .timeline-card ul li:hover::before {
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .journey-title {
      margin-bottom: 48px;
    }

    .journey-title::before {
      left: 0;
      right: 0;
    }

    .journey-title span {
      padding: 12px 26px;
      font-size: clamp(1.4rem, 6vw, 2rem);
    }

    .timeline-line {
      left: 16px;
      width: 4px;
      box-shadow: 0 0 10px rgba(59,130,246,0.4);
    }
    .timeline-card {
      margin-left: 40px;
      width: calc(100% - 60px);
      transform: none;
      max-width: none;
      padding: 40px;
    }
    .timeline-card:hover {
      transform: none;
      box-shadow:
        0 0 22px rgba(96, 165, 250, 0.25),
        0 0 20px rgba(251, 146, 60, 0.2);
    }
    .timeline-card ul li:hover {
      transform: translateX(2px);
    }
    .timeline-date {
      left: 16px;
      right: auto;
      transform: translateX(0);
      top: 10px;
    }
    .timeline-date::before {
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('visible');
          }, index * 200);
        }
      });
    }, observerOptions);

    const timelineItems = document.querySelectorAll('.timeline-item');
    timelineItems.forEach(item => observer.observe(item));
  });
</script>