---
// Experience component for portfolio
---

import { BsPersonWorkspace } from 'react-icons/bs';
import { Calendar } from 'lucide-react';

<section id="experience" class="experience-section py-20" style="background: radial-gradient(circle at center, #0f172a, #020617);">
  <div class="container mx-auto px-4">
    <h2 class="text-center text-4xl font-bold text-Text-light mb-16">Professional Journey</h2>

    <div class="timeline relative max-w-4xl mx-auto">
      <!-- Timeline Line -->
      <div class="timeline-line absolute left-1/2 transform -translate-x-1/2 w-1 bg-gradient-to-b from-blue-400 to-blue-600 h-full rounded-full"></div>

      <!-- Experience Item 1 - Left -->
      <div class="timeline-item relative mb-12">
        <div class="timeline-date absolute left-1/2 -translate-x-1/2 top-12 z-10">
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 px-4 py-2 rounded-full flex items-center gap-2 text-slate-400 text-sm font-medium">
            <Calendar className="w-4 h-4 text-blue-400" />
            Jan 2026 – Mar 2026
          </div>
        </div>
        <div class="timeline-node absolute left-4 md:left-1/2 md:-translate-x-1/2 top-0 w-12 h-12 rounded-xl bg-[#050505] border border-blue-400/40 flex items-center justify-center z-10 shadow-[0_0_20px_rgba(59,130,246,0.5)]">
          <BsPersonWorkspace className="text-blue-400 w-5 h-5" />
        </div>
        <div class="flex items-center">
          <div class="timeline-content w-full md:w-[55%] md:pr-8 text-right mr-14">
            <div class="timeline-card bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-xl p-10 shadow-lg hover:shadow-[0_0_15px_rgba(59,130,246,0.4)] transition-all duration-300 hover:-translate-y-1">
              <h3 class="text-2xl font-bold text-Text-light mb-2">Full Stack Developer Intern</h3>
              <h4 class="text-lg text-blue-400 font-medium mb-4">Happieloop Technologies</h4>
              <ul class="text-Text-light/80 text-sm lg:text-[15px] space-y-2">
                <li class="flex items-start justify-end">
                  Developed responsive web applications using HTML, CSS, and JavaScript
                </li>
                <li class="flex items-start justify-end">
                  Built scalable backend APIs using Node.js and Express.js
                </li>
                <li class="flex items-start justify-end">
                  Designed and managed MongoDB databases for real-time applications
                </li>
                <li class="flex items-start justify-end">
                  Integrated REST APIs and implemented real-time features using WebSocket
                </li>
                <li class="flex items-start justify-end">
                  Improved application performance, debugging, and reliability
                </li>
              </ul>
            </div>
          </div>
          <div class="hidden md:block w-[45%]"></div>
        </div>
      </div>

      <!-- Experience Item 2 - Right -->
      <div class="timeline-item relative mb-12">
        <div class="timeline-date absolute left-1/2 -translate-x-1/2 top-12 z-10">
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 px-4 py-2 rounded-full flex items-center gap-2 text-slate-400 text-sm font-medium">
            <Calendar className="w-4 h-4 text-blue-400" />
            2025 – Present
          </div>
        </div>
        <div class="timeline-node absolute left-4 md:left-1/2 md:-translate-x-1/2 top-0 w-12 h-12 rounded-xl bg-[#050505] border border-blue-400/40 flex items-center justify-center z-10 shadow-[0_0_20px_rgba(59,130,246,0.5)]">
          <BsPersonWorkspace className="text-blue-400 w-5 h-5" />
        </div>
        <div class="flex items-center">
          <div class="hidden md:block w-[45%]"></div>
          <div class="timeline-content w-full md:w-[55%] md:pl-8 ml-14">
            <div class="timeline-card bg-white/[0.04] backdrop-blur-xl border border-white/10 rounded-xl p-10 shadow-lg hover:shadow-[0_0_15px_rgba(59,130,246,0.4)] transition-all duration-300 hover:-translate-y-1">
              <h3 class="text-2xl font-bold text-Text-light mb-2">Software Development Intern</h3>
              <h4 class="text-lg text-blue-400 font-medium mb-4">Infosys Springboard</h4>
              <ul class="text-Text-light/80 text-sm lg:text-[15px] space-y-3">
                <li class="flex items-start">
                  Developed an automated regression testing web application to streamline testing workflows
                </li>
                <li class="flex items-start">
                  Designed test automation logic to significantly reduce manual testing effort
                </li>
                <li class="flex items-start">
                  Built backend services and integrated automated testing pipelines
                </li>
                <li class="flex items-start">
                  Focused on improving testing speed, accuracy, and reliability
                </li>
                <li class="flex items-start">
                  Implemented efficient debugging and error-handling mechanisms
                </li>
                <!-- <li class="flex items-start">
                  Worked with modern web technologies to build scalable and maintainable solutions
                </li> -->
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .timeline-line {
    background: linear-gradient(to bottom, #3b82f6, #60a5fa);
    box-shadow: 0 0 10px rgba(59,130,246,0.4);
    width: 2px;
  }

  .timeline-item {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: auto;
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    max-width: 500px;
    width: 100%;
    padding: 40px;
  }

  .timeline-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 0 25px rgba(59,130,246,0.4);
  }

  .timeline-date {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 48px;
    border-radius: 999px;
    padding: 8px 16px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    font-size: 14px;
    color: #94a3b8;
    z-index: 1;
  }

  .timeline-date::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background: #3b82f6;
    border-radius: 50%;
    box-shadow: 0 0 10px #3b82f6;
    z-index: -1;
  }

  .timeline-card h3 {
    font-size: 22px;
    color: #ffffff;
  }

  .timeline-card h4 {
    font-size: 18px;
    color: #3b82f6;
  }

  .timeline-card ul {
    list-style: none;
    padding-left: 0;
  }

  .timeline-card ul li {
    line-height: 1.6;
    color: #cbd5e1;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .timeline-card ul li::before {
    content: "›";
    color: #3b82f6;
    font-weight: bold;
  }

  .timeline-card ul li:hover {
    transform: translateX(3px);
    color: #ffffff;
  }

  .timeline-card ul li:hover::before {
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .timeline-line {
      left: 16px;
      width: 4px;
      box-shadow: 0 0 10px rgba(59,130,246,0.4);
    }
    .timeline-card {
      margin-left: 40px;
      width: calc(100% - 60px);
      transform: none;
      max-width: none;
      padding: 40px;
    }
    .timeline-card:hover {
      transform: none;
      box-shadow: 0 0 25px rgba(59,130,246,0.4);
    }
    .timeline-card ul li:hover {
      transform: translateX(2px);
    }
    .timeline-date {
      left: 16px;
      transform: translateX(0);
      top: 48px;
    }
    .timeline-date::before {
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('visible');
          }, index * 200);
        }
      });
    }, observerOptions);

    const timelineItems = document.querySelectorAll('.timeline-item');
    timelineItems.forEach(item => observer.observe(item));
  });
</script>