---
import IconsTecnology from "./IconsTecnology.astro";
import LinkedInIcon from "./LinkedInIcon.astro";

const EMAIL = "gurusharan4666@gmail.com";
const GITHUB_URL = "https://github.com/123GuruSharan";
const LINKEDIN_URL = "https://linkedin.com/in/guru-sharan-kumar-priye";
/** Resume viewer page */
const RESUME_URL = "/resume";
---

<section id="contact" class="scroll-mt-[100px]" data-astro-rerun-on-hydrate>
  <div class="container contenedor-revelar mx-auto px-4 py-20 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4 dark:text-white max-w-3xl mx-auto leading-tight">
      Let’s Work Together
    </h2>
    <p
      class="font-medium text-base sm:text-lg text-body dark:text-body-light mb-10 max-w-2xl mx-auto"
    >
      Currently available for opportunities
    </p>
    <a
      href={`mailto:${EMAIL}`}
      class="inline-flex items-center justify-center mb-10 px-7 py-3 rounded-lg bg-Orange-vibrant text-white dark:bg-Orange-vibrant-dark font-semibold shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5"
      data-track-event="contact_click"
      data-track-label="hire_me_button"
      data-track-location="contact"
    >
      Hire Me
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
      <!-- Form -->
      <div
        class="item-revelar contact-form bg-neutral-primary-soft border border-Border dark:border-Border-dark rounded-base shadow-xs p-8"
      >
        <div class="flex items-center align-middle gap-4 mb-6">
          <svg
            class="w-8 h-8 text-Orange-vibrant dark:text-Orange-vibrant-dark shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          <h3
            class="text-2xl font-bold text-Text-dark dark:text-Text-light text-left"
          >
            Send message
          </h3>
        </div>

        <div
          class="flex flex-wrap gap-2 sm:gap-3 mb-8 justify-start"
        >
          <a
            href={RESUME_URL}
            class="contact-quick-btn"
            data-track-event="resume_download"
            data-track-label="contact_view_resume"
            data-track-location="contact"
          >
            View Resume
          </a>
          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-quick-btn"
            data-track-event="contact_click"
            data-track-label="contact_github_quick"
            data-track-location="contact"
          >
            GitHub
          </a>
          <a
            href={LINKEDIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-quick-btn"
            data-track-event="contact_click"
            data-track-label="contact_linkedin_quick"
            data-track-location="contact"
          >
            LinkedIn
          </a>
        </div>

        <form id="contact-form" class="space-y-6 text-left" method="POST">
          <div>
            <label
              for="name"
              class="block mb-2 text-sm font-medium text-Text-dark dark:text-Text-light"
            >
              Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              class="contact-input bg-Background-light dark:bg-Background-dark border border-Border dark:border-Border-dark text-Text-dark dark:text-Text-light text-sm rounded-base block w-full px-4 py-3 shadow-xs placeholder:text-body dark:placeholder:text-body-light"
              placeholder="Your name"
              required
            />
          </div>

          <div>
            <label
              for="email"
              class="block mb-2 text-sm font-medium text-Text-dark dark:text-Text-light"
            >
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              class="contact-input bg-Background-light dark:bg-Background-dark border border-Border dark:border-Border-dark text-Text-dark dark:text-Text-light text-sm rounded-base block w-full px-4 py-3 shadow-xs placeholder:text-body dark:placeholder:text-body-light"
              placeholder="your.email@example.com"
              required
            />
          </div>

          <div>
            <label
              for="message"
              class="block mb-2 text-sm font-medium text-Text-dark dark:text-Text-light"
            >
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              class="contact-input bg-Background-light dark:bg-Background-dark border border-Border dark:border-Border-dark text-Text-dark dark:text-Text-light text-sm rounded-base block w-full px-4 py-3 shadow-xs placeholder:text-body dark:placeholder:text-body-light resize-none"
              placeholder="Write your message here..."
              required></textarea>
          </div>

          <div id="result" class="text-sm font-medium hidden"></div>

          <button
            type="submit"
            id="submit-btn"
            class="contact-submit-btn px-8 py-4 font-semibold rounded-lg transition-all duration-300 shadow-lg hover:shadow-cyan-500/25 hover:scale-105 inline-flex items-center cursor-pointer justify-center gap-2 bg-Orange-vibrant dark:bg-Orange-vibrant-dark hover:bg-Orange-vibrant/90 w-full disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
            data-track-event="contact_click"
            data-track-label="contact_form_submit"
            data-track-location="contact"
          >
            <span id="btn-text">Send Message 🚀</span>
            <span id="btn-loading" class="hidden">Sending...</span>
          </button>
        </form>
      </div>

      <!-- Contact info -->
      <div
        class="item-revelar contact-info bg-neutral-primary-soft border border-Border dark:border-Border-dark rounded-base shadow-xs p-8 space-y-6 text-left"
      >
        <h3 class="text-2xl font-bold text-Text-dark dark:text-Text-light mb-4">
          Contact Information
        </h3>

        <div
          class="flex items-start gap-4 pb-4 border-b border-Border dark:border-Border-dark"
        >
          <div
            class="bg-Orange-vibrant/10 dark:bg-Orange-vibrant-dark/10 p-3 rounded-base shrink-0"
          >
            <svg
              class="w-6 h-6 text-Orange-vibrant dark:text-Orange-vibrant-dark"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-Text-dark dark:text-Text-light mb-1">
              Email
            </h4>
            <a
              href={`mailto:${EMAIL}`}
              class="text-body w-auto text-sm dark:text-body-light hover:text-Orange-vibrant dark:hover:text-Orange-vibrant-dark transition-colors break-all"
            >
              {EMAIL}
            </a>
            <p class="text-xs text-body dark:text-body-light/90 mt-1">
              Let's talk
            </p>
          </div>
        </div>

        <div
          class="flex items-start gap-4 pb-4 border-b border-Border dark:border-Border-dark"
        >
          <div
            class="bg-Orange-vibrant/10 dark:bg-Orange-vibrant-dark/10 p-3 rounded-base shrink-0"
          >
            <svg
              class="w-6 h-6 text-Orange-vibrant dark:text-Orange-vibrant-dark"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-Text-dark dark:text-Text-light mb-1">
              Location
            </h4>
            <p class="text-body text-sm dark:text-body-light">India</p>
          </div>
        </div>

        <div
          class="flex items-start gap-4 pb-4 border-b border-Border dark:border-Border-dark"
        >
          <div
            class="bg-green-500/10 dark:bg-green-500/15 p-3 rounded-base shrink-0"
          >
            <svg
              class="w-6 h-6 text-green-600 dark:text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-Text-dark dark:text-Text-light mb-1">
              Availability
            </h4>
            <p
              class="text-sm text-body dark:text-body-light flex flex-wrap items-center gap-2"
            >
              <span
                class="inline-flex h-2.5 w-2.5 shrink-0 rounded-full bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.85)]"
                aria-hidden="true"
              ></span>
              Available for opportunities
            </p>
          </div>
        </div>

        <div>
          <h4 class="font-bold text-Text-dark dark:text-Text-light mb-3">
            Connect with me
          </h4>
          <div class="flex gap-4">
            <a
              href={GITHUB_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-social-link text-Text-dark dark:text-Text-light"
              aria-label="GitHub"
            >
              <IconsTecnology name="Github" size={24} />
            </a>
            <a
              href={LINKEDIN_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-social-link text-Text-dark dark:text-Text-light"
              aria-label="LinkedIn"
            >
              <LinkedInIcon size={24} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .contact-quick-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
      font-weight: 600;
      border-radius: 9999px;
      border: 1px solid var(--color-Border);
      background: var(--color-Background-light);
      color: var(--color-Text-dark);
      transition:
        transform 0.25s ease,
        box-shadow 0.25s ease,
        border-color 0.25s ease,
        background-color 0.25s ease;
    }

    .dark .contact-quick-btn {
      border-color: var(--color-Border-dark);
      background: var(--color-Background-dark);
      color: var(--color-Text-light);
    }

    .contact-quick-btn:hover {
      transform: translateY(-1px) scale(1.02);
      border-color: var(--color-Orange-vibrant);
      box-shadow:
        0 0 20px rgba(251, 146, 60, 0.35),
        0 4px 14px rgba(0, 0, 0, 0.08);
    }

    .dark .contact-quick-btn:hover {
      border-color: var(--color-Orange-vibrant-dark);
      box-shadow:
        0 0 22px rgba(251, 146, 60, 0.28),
        0 4px 14px rgba(0, 0, 0, 0.35);
    }

    .contact-input {
      transition:
        border-color 0.2s ease,
        box-shadow 0.2s ease;
    }

    .contact-input:focus {
      outline: none;
      border-color: var(--color-Orange-vibrant);
      box-shadow:
        0 0 0 3px rgba(251, 146, 60, 0.22),
        0 0 18px rgba(251, 146, 60, 0.15);
    }

    .dark .contact-input:focus {
      border-color: var(--color-Orange-vibrant-dark);
      box-shadow:
        0 0 0 3px rgba(251, 146, 60, 0.25),
        0 0 20px rgba(251, 146, 60, 0.12);
    }

    .contact-submit-btn:not(:disabled):hover {
      box-shadow:
        0 12px 32px rgba(251, 146, 60, 0.45),
        0 0 28px rgba(96, 165, 250, 0.2),
        0 0 24px rgba(251, 146, 60, 0.3);
    }

    .contact-social-link {
      display: inline-flex;
      transition:
        transform 0.25s ease,
        color 0.25s ease,
        filter 0.25s ease;
    }

    .contact-social-link:hover {
      transform: scale(1.12);
      color: var(--color-Orange-vibrant);
      filter: drop-shadow(0 0 8px rgba(251, 146, 60, 0.55));
    }

    .dark .contact-social-link:hover {
      color: var(--color-Orange-vibrant-dark);
      filter: drop-shadow(0 0 10px rgba(251, 146, 60, 0.45));
    }
  </style>

  <script is:inline>
    (function () {
      var EMAILJS_SRC =
        "https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js";
      var PUBLIC_KEY = "QVSetrXkf7f0AoTsi";
      var SERVICE_ID = "service_wir8uv6";
      var TEMPLATE_ID = "template_9p0sth5";

      var emailjsReady = null;
      var emailjsInited = false;

      function loadEmailJs() {
        if (typeof window.emailjs !== "undefined") {
          return Promise.resolve(window.emailjs);
        }
        if (emailjsReady) return emailjsReady;

        emailjsReady = new Promise(function (resolve, reject) {
          function fail() {
            emailjsReady = null;
            reject(new Error("EmailJS script failed to load"));
          }
          var s = document.querySelector("script[data-emailjs-cdn]");
          if (s) {
            if (typeof window.emailjs !== "undefined") {
              resolve(window.emailjs);
              return;
            }
            s.addEventListener("load", function () {
              resolve(window.emailjs);
            });
            s.addEventListener("error", fail);
            return;
          }
          var script = document.createElement("script");
          script.src = EMAILJS_SRC;
          script.async = true;
          script.setAttribute("data-emailjs-cdn", "1");
          script.onload = function () {
            resolve(window.emailjs);
          };
          script.onerror = fail;
          document.head.appendChild(script);
        });

        return emailjsReady;
      }

      function ensureEmailJsInit(emailjs) {
        if (!emailjsInited && emailjs && typeof emailjs.init === "function") {
          emailjs.init(PUBLIC_KEY);
          emailjsInited = true;
        }
      }

      function initContactForm() {
        var form = document.getElementById("contact-form");
        var result = document.getElementById("result");
        var submitBtn = document.getElementById("submit-btn");
        var btnText = document.getElementById("btn-text");
        var btnLoading = document.getElementById("btn-loading");

        if (!form || !submitBtn || !result) return;
        if (form.getAttribute("data-emailjs-bound") === "1") return;
        form.setAttribute("data-emailjs-bound", "1");

        form.addEventListener("submit", function (e) {
          e.preventDefault();

          submitBtn.disabled = true;
          btnText.classList.add("hidden");
          btnLoading.classList.remove("hidden");
          result.classList.add("hidden");

          loadEmailJs()
            .then(function (emailjs) {
              ensureEmailJsInit(emailjs);
              return emailjs.sendForm(SERVICE_ID, TEMPLATE_ID, form);
            })
            .then(function () {
              result.textContent =
                "Message sent successfully. I'll get back to you soon!";
              result.className =
                "text-sm font-medium text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 p-3 rounded-base";
              result.classList.remove("hidden");
              form.reset();
            })
            .catch(function (err) {
              console.error("EmailJS error:", err);
              result.textContent =
                "Something went wrong. Please try again in a moment or email me directly.";
              result.className =
                "text-sm font-medium text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 p-3 rounded-base";
              result.classList.remove("hidden");
            })
            .finally(function () {
              submitBtn.disabled = false;
              btnText.classList.remove("hidden");
              btnLoading.classList.add("hidden");
            });
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initContactForm);
      } else {
        initContactForm();
      }

      document.addEventListener("astro:after-swap", initContactForm);
      document.addEventListener("astro:page-load", initContactForm);
    })();
  </script>
</section>
