---
import { getCollection } from "astro:content";
import CertificateCard from "./CertificateCard.astro";

const allCertificates = await getCollection("certificates");
const certificates = allCertificates.sort(
  (a, b) => (a.data.order || 0) - (b.data.order || 0),
);
---

<section id="certificates" class="certificates flex flex-col justify-center py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-4xl font-bold mb-4 dark:text-white">Certificates</h2>
      <p class="font-medium text-lg text-body dark:text-body-light">
        A collection of my certifications and achievements.
      </p>
    </div>
    <div
      class="grid grid-cols-1 gap-8 place-items-center md:grid-cols-2 xl:grid-cols-3"
    >
      {
        certificates.map((certificate) => (
          <CertificateCard
            title={certificate.data.title}
            description={certificate.data.description}
            imageUrl={certificate.data.image}
            verifyLink={certificate.data.verifyLink}
            issuedDate={certificate.data.issuedDate}
          />
        ))
      }
    </div>
  </div>
</section>
