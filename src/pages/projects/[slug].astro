---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import Badge from "../../components/badge.astro";
import IconsTecnology from "../../components/IconsTecnology.astro";
import CodeIcon from "../../components/CodeIcon.astro";
import MessageIcon from "../../components/MessageIcon.astro";
import HouseIcon from "../../components/HouseIcon.astro";
import UserIcon from "../../components/UserIcon.astro";

export const getStaticPaths = (async () => {
  const projectEntries = await getCollection("projects");
  return projectEntries.map((entry) => ({
    params: { slug: entry.id.replace(".md", "") },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await entry.render();

// Map icon names to components
const iconComponents = {
  code: CodeIcon,
  message: MessageIcon,
  house: HouseIcon,
  user: UserIcon,
};

const IconComponent = iconComponents[entry.data.icon || "code"];
---

<Layout
  title={`${entry.data.title} | GuruSharan.dev`}
  description={entry.data.description}
>
  <Header />

  <main
    class="min-h-screen bg-Background-light dark:bg-Background-dark relative overflow-hidden"
  >
    <!-- Atmospheric background -->
    <div
      class="absolute inset-0 bg-linear-to-tr from-Orange-vibrant/5 via-transparent to-Cyan-accent/5 dark:from-Orange-vibrant-dark/5 dark:to-Cyan-accent-dark/5 pointer-events-none"
    >
    </div>
    <div
      class="absolute top-1/4 left-0 w-1/3 h-1/3 bg-Orange-vibrant/3 dark:bg-Orange-vibrant-dark/3 blur-[120px] pointer-events-none"
    >
    </div>

    <!-- Hero Section with Full-Width Image -->
    <div class="relative h-[70vh] md:h-[80vh] overflow-hidden">
      <!-- Back button (absolute positioned over image) -->
      <a
        href="/projects"
        class="absolute top-20 md:top-20 left-4 md:left-8 z-10 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/90 dark:bg-black/90 backdrop-blur-sm text-Text-dark dark:text-Text-light hover:bg-Orange-vibrant hover:text-white dark:hover:bg-Orange-vibrant-dark transition-all duration-300 group shadow-lg"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:-translate-x-1 transition-transform"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        <span class="text-sm font-medium">Proyectos</span>
      </a>

      <!-- Project Image -->
      <div class="absolute inset-0">
        <Image
          src={entry.data.image}
          alt={entry.data.title}
          class="w-full h-full object-cover"
          widths={[1200, 1600, 2000]}
          sizes="100vw"
        />
        <div
          class="absolute inset-0 bg-linear-to-t from-Background-light via-Background-light/50 to-transparent dark:from-Background-dark dark:via-Background-dark/50"
        >
        </div>
      </div>

      <!-- Hero Content -->
      <div class="absolute bottom-0 left-0 right-0 p-8 md:p-16">
        <div class="max-w-7xl mx-auto">
          <div class="max-w-4xl">
            <!-- Title -->
            <h1
              class="text-5xl md:text-7xl xl:text-8xl font-bold mb-6 text-Text-dark dark:text-white leading-[0.95] tracking-tight"
            >
              {entry.data.title}
            </h1>

            <!-- Technologies Pills -->
            <div class="flex flex-wrap gap-2 mb-6">
              {entry.data.technologies.map((tech) => <Badge label={tech} />)}
            </div>

            <!-- Metadata -->
            <div
              class="flex flex-wrap items-center gap-6 text-sm text-body dark:text-body-light"
            >
              <div class="flex items-center gap-2">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
                  <line x1="16" x2="16" y1="2" y2="6"></line>
                  <line x1="8" x2="8" y1="2" y2="6"></line>
                  <line x1="3" x2="21" y1="10" y2="10"></line>
                </svg>
                <span>
                  {
                    new Date(entry.data.publishedDate).toLocaleDateString(
                      "es-ES",
                      {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      },
                    )
                  }
                </span>
              </div>
              <div class="w-1 h-1 rounded-full bg-body dark:bg-body-light">
              </div>
              <span>{entry.data.technologies.length} tecnologías</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Content Section -->
    <article class="relative py-20 px-6 md:px-16">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
          <!-- Main Content -->
          <div class="lg:col-span-8">
            <!-- Description -->
            <div class="mb-16">
              <p
                class="text-2xl md:text-3xl text-Text-dark dark:text-white leading-relaxed font-light"
              >
                {entry.data.description}
              </p>
            </div>

            <!-- Divider -->
            <div
              class="h-px bg-linear-to-r from-Orange-vibrant/50 via-Cyan-accent/50 to-transparent dark:from-Orange-vibrant-dark/50 dark:via-Cyan-accent-dark/50 mb-16"
            >
            </div>

            <!-- Markdown Content -->
            <div
              class="text-base leading-relaxed text-Text-dark dark:text-Text-light space-y-8"
            >
              <Content />
            </div>
          </div>

          <!-- Sidebar -->
          <aside class="lg:col-span-4">
            <div class="sticky top-32 space-y-8">
              <!-- Actions Card -->
              <div
                class="p-8 rounded-2xl bg-neutral-primary-soft dark:bg-card-surface-dark border border-Border dark:border-Border-dark"
              >
                <h3
                  class="text-sm font-mono uppercase tracking-wider text-body dark:text-body-light mb-6"
                >
                  Acciones
                </h3>
                <div class="space-y-3">
                  <a
                    href={entry.data.projectUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-between w-full px-6 py-4 text-white bg-Orange-vibrant hover:bg-Orange-vibrant/90 dark:bg-Orange-vibrant-dark dark:hover:bg-Orange-vibrant-dark/90 rounded-xl transition-all font-medium shadow-lg hover:shadow-xl hover:-translate-y-0.5 group"
                  >
                    <span>Ver en GitHub</span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="group-hover:translate-x-1 transition-transform"
                    >
                      <path d="M7 7h10v10"></path>
                      <path d="M7 17 17 7"></path>
                    </svg>
                  </a>
                  <button
                    onclick="if(navigator.share){navigator.share({title: document.title, url: window.location.href})}else{navigator.clipboard.writeText(window.location.href);alert('Enlace copiado')}"
                    class="flex items-center justify-between w-full px-6 py-4 text-Text-dark dark:text-Text-light bg-white dark:bg-Background-dark border-2 border-Border dark:border-Border-dark hover:border-Orange-vibrant dark:hover:border-Orange-vibrant-dark rounded-xl transition-all font-medium hover:-translate-y-0.5 group"
                  >
                    <span>Compartir</span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="group-hover:translate-x-1 transition-transform"
                    >
                      <path
                        d="M13 3H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-3"
                      ></path>
                      <path d="M8 21h8"></path>
                      <path d="M12 17v4"></path>
                      <path d="m17 8 5-5"></path>
                      <path d="M17 3h5v5"></path>
                    </svg>
                  </button>
                </div>
              </div>

              <!-- Tech Stack Card -->
              <div
                class="p-8 rounded-2xl bg-neutral-primary-soft dark:bg-card-surface-dark border border-Border dark:border-Border-dark"
              >
                <h3
                  class="text-sm font-mono uppercase tracking-wider text-body dark:text-body-light mb-6"
                >
                  Tech Stack
                </h3>
                <div class="space-y-3">
                  {
                    entry.data.technologies.map((tech) => (
                      <div class="flex items-center gap-3 p-3 rounded-lg bg-white dark:bg-Background-dark border border-Border/50 dark:border-Border-dark/50 hover:border-Orange-vibrant dark:hover:border-Orange-vibrant-dark transition-colors">
                        <IconsTecnology
                          name={tech.toLowerCase()}
                          size={24}
                          useOriginalColor={true}
                        />
                        <span class="text-sm font-medium text-Text-dark dark:text-Text-light">{tech}</span>
                      </div>
                    ))
                  }
                </div>
              </div>

              <!-- More Projects CTA -->
              <div
                class="p-8 rounded-2xl bg-linear-to-br from-Orange-vibrant/10 to-Cyan-accent/10 dark:from-Orange-vibrant-dark/10 dark:to-Cyan-accent-dark/10 border border-Orange-vibrant/20 dark:border-Orange-vibrant-dark/20"
              >
                <h3
                  class="text-lg font-bold text-Text-dark dark:text-white mb-2"
                >
                  Más proyectos
                </h3>
                <p class="text-sm text-body dark:text-body-light mb-4">
                  Explora más trabajos y descubre otras soluciones.
                </p>
                <a
                  href="/projects"
                  class="inline-flex items-center gap-2 text-Orange-vibrant dark:text-Orange-vibrant-dark font-medium hover:gap-3 transition-all group"
                >
                  <span>Ver todos</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="m9 18 6-6-6-6"></path>
                  </svg>
                </a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  /* Entrance animations */
  article {
    animation: fadeIn 0.8s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }

  /* View Transitions */
  @view-transition {
    navigation: auto;
  }

  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.5s;
    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Custom scrollbar for code blocks */
  pre::-webkit-scrollbar {
    height: 8px;
  }

  pre::-webkit-scrollbar-track {
    background: transparent;
  }

  pre::-webkit-scrollbar-thumb {
    background: var(--color-Border);
    border-radius: 4px;
  }

  pre::-webkit-scrollbar-thumb:hover {
    background: var(--color-Orange-vibrant);
  }

  /* Atmospheric animation */
  .absolute.inset-0 {
    animation: drift 25s ease-in-out infinite;
  }

  @keyframes drift {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(20px, -20px) scale(1.05);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.95);
    }
  }
</style>
