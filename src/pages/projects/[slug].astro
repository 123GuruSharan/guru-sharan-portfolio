---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import Badge from "../../components/badge.astro";
import IconsTecnology from "../../components/IconsTecnology.astro";
import CodeIcon from "../../components/CodeIcon.astro";
import MessageIcon from "../../components/MessageIcon.astro";
import HouseIcon from "../../components/HouseIcon.astro";
import UserIcon from "../../components/UserIcon.astro";

export const getStaticPaths = (async () => {
  const projectEntries = await getCollection("projects");
  return projectEntries.map((entry) => ({
    params: { slug: entry.id.replace(".md", "") },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await entry.render();

// Map icon names to components
const iconComponents = {
  code: CodeIcon,
  message: MessageIcon,
  house: HouseIcon,
  user: UserIcon,
};

const IconComponent = iconComponents[entry.data.icon || "code"];
---

<Layout
  title={`${entry.data.title} | LugoTech`}
  description={entry.data.description}
>
  <Header />

  <main
    class="min-h-screen py-20 px-6 md:px-4 bg-Background-light dark:bg-Background-dark"
  >
    <article class="max-w-5xl mx-auto">
      <!-- Back button -->
      <a
        href="/projects"
        class="inline-flex items-center gap-2 text-body dark:text-body-light hover:text-Orange-vibrant dark:hover:text-Orange-vibrant-dark transition-colors mb-8 group"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:-translate-x-1 transition-transform"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Volver a proyectos
      </a>

      <!-- Project header -->
      <header class="mb-10">
        <div class="flex items-start gap-4 mb-6">
          <div class="shrink-0"></div>
          <div class="flex-1">
            <h1
              class="text-4xl md:text-4xl font-bold text-Text-dark dark:text-white mb-3"
            >
              {entry.data.title}
            </h1>
          </div>
        </div>

        <!-- Metadata bar -->
        <div
          class="flex flex-wrap items-center gap-6 mb-6 text-sm text-body dark:text-body-light"
        >
          <div class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
              <line x1="16" x2="16" y1="2" y2="6"></line>
              <line x1="8" x2="8" y1="2" y2="6"></line>
              <line x1="3" x2="21" y1="10" y2="10"></line>
            </svg>
            <span>
              {
                new Date(entry.data.publishedDate).toLocaleDateString("es-ES", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })
              }
            </span>
          </div>
          <div class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
            <span>{entry.data.technologies.length} tecnologías</span>
          </div>
        </div>

        <!-- Technologies -->
        <div class="flex flex-wrap gap-2 mb-8">
          {entry.data.technologies.map((tech) => <Badge label={tech} />)}
        </div>

        <!-- Action buttons -->
        <div class="flex flex-wrap gap-4">
          <a
            href={entry.data.projectUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 text-white bg-Orange-vibrant hover:bg-Orange-vibrant/90 dark:bg-Orange-vibrant-dark dark:hover:bg-Orange-vibrant-dark/90 rounded-base transition-all font-medium shadow-lg hover:shadow-xl hover:-translate-y-0.5"
          >
            <IconsTecnology name="github" size={20} class="text-white" />
            Ver en GitHub
          </a>
          <button
            onclick="if(navigator.share){navigator.share({title: document.title, url: window.location.href})}else{navigator.clipboard.writeText(window.location.href);alert('Enlace copiado al portapapeles')}"
            class="inline-flex items-center gap-2 px-6 py-3 text-Text-dark dark:text-Text-light bg-neutral-primary-soft hover:bg-neutral-secondary-soft dark:bg-card-surface-dark dark:hover:bg-card-surface-dark/80 border border-Border dark:border-Border-dark rounded-base transition-all font-medium hover:-translate-y-0.5"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M13 3H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-3"
              ></path>
              <path d="M8 21h8"></path>
              <path d="M12 17v4"></path>
              <path d="m17 8 5-5"></path>
              <path d="M17 3h5v5"></path>
            </svg>
            Compartir
          </button>
        </div>
      </header>

      <!-- Project image -->
      <div
        class="w-full h-64 md:h-[500px] overflow-hidden rounded-base shadow-2xl mb-12 border border-Border dark:border-Border-dark"
      >
        <Image
          src={entry.data.image}
          alt={entry.data.title}
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          widths={[800, 1200, 1600]}
          sizes="(max-width: 768px) 100vw, 1200px"
        />
      </div>

      <!-- Project content (markdown) -->
      <div class="text-base leading-relaxed text-body">
        <Content />
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  /* Smooth transitions */
  * {
    transition-property: color, background-color, border-color;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
  }

  /* Remove transition from specific elements */
  img,
  svg {
    transition: transform 0.3s ease;
  }
</style>
