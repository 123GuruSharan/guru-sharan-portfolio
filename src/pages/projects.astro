---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";

// Get all projects and sort them
const allProjects = await getCollection("projects");
const projects = allProjects.sort(
  (a, b) => (a.data.order || 0) - (b.data.order || 0),
);

// Get all unique technologies
const allTechnologies = [...new Set(projects.flatMap(p => p.data.technologies))].sort();
---

<Layout
  title="Projects | GuruSharan.dev"
  description="Explore all my full-stack development projects. Innovative solutions and clean code."
>
  <Header />

  <main class="min-h-screen bg-Background-light dark:bg-Background-dark relative overflow-hidden">
    <!-- Atmospheric background -->
    <div class="absolute inset-0 bg-gradient-to-br from-Orange-vibrant/5 via-transparent to-Cyan-accent/5 dark:from-Orange-vibrant-dark/5 dark:to-Cyan-accent-dark/5 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-Cyan-accent/3 dark:bg-Cyan-accent-dark/3 blur-[120px] pointer-events-none"></div>

    <section class="relative py-32 px-6 md:px-8">
      <div class="max-w-7xl mx-auto w-full">
        <!-- Hero Section -->
        <div class="mb-20">
          <div class="max-w-5xl">
            <h1 class="text-7xl md:text-8xl xl:text-9xl font-bold mb-8 text-Text-dark dark:text-white leading-[0.9] tracking-tight">
              Projects<span class="text-Orange-vibrant dark:text-Orange-vibrant-dark">.</span>
            </h1>
            <p class="text-xl md:text-2xl text-body dark:text-body-light max-w-2xl leading-relaxed font-light">
              A collection of innovative solutions and clean code.
              <span class="text-Text-dark dark:text-Text-light font-medium">Explore, filter, get inspired.</span>
            </p>
          </div>
        </div>

        <!-- Filter Section -->
        <div class="mb-16">
          <div class="flex items-center gap-4 mb-6">
            <span class="text-sm font-mono uppercase tracking-wider text-body dark:text-body-light">
              Filter by
            </span>
            <div class="h-px bg-Border dark:bg-Border-dark flex-1"></div>
          </div>

          <div class="flex flex-wrap gap-3">
            <button
              data-filter="all"
              class="filter-btn active group relative px-6 py-3 rounded-full text-sm font-medium transition-all duration-300 bg-Orange-vibrant text-white dark:bg-Orange-vibrant-dark overflow-hidden"
            >
              <span class="relative z-10">All</span>
              <span class="filter-count ml-2 relative z-10 opacity-75">{projects.length}</span>
              <div class="absolute inset-0 bg-gradient-to-r from-Orange-vibrant to-Cyan-accent dark:from-Orange-vibrant-dark dark:to-Cyan-accent-dark opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </button>
            {allTechnologies.map((tech) => {
              const count = projects.filter(p => p.data.technologies.includes(tech)).length;
              return (
                <button
                  data-filter={tech}
                  class="filter-btn group relative px-6 py-3 rounded-full text-sm font-medium transition-all duration-300 bg-neutral-primary-soft dark:bg-card-surface-dark text-Text-dark dark:text-Text-light hover:bg-Orange-vibrant hover:text-white dark:hover:bg-Orange-vibrant-dark border border-Border dark:border-Border-dark hover:border-Orange-vibrant dark:hover:border-Orange-vibrant-dark overflow-hidden"
                >
                  <span class="relative z-10">{tech}</span>
                  <span class="filter-count ml-2 relative z-10 opacity-60 group-hover:opacity-100">{count}</span>
                  <div class="absolute inset-0 bg-Orange-vibrant dark:bg-Orange-vibrant-dark opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                </button>
              );
            })}
          </div>
        </div>

        <!-- Projects Counter -->
        <div class="mb-8">
          <p id="projects-counter" class="text-sm font-mono text-body dark:text-body-light">
            <span class="text-Orange-vibrant dark:text-Orange-vibrant-dark font-bold" id="visible-count">{projects.length}</span>
            <span class="mx-2">/</span>
            <span>{projects.length} projects</span>
          </p>
        </div>

        <!-- Projects Grid with Masonry-style -->
        <div
          id="projects-grid"
          class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 auto-rows-auto"
        >
          {
            projects.map((project, index) => (
              <div
                class="project-item"
                data-technologies={JSON.stringify(project.data.technologies)}
                style={`animation-delay: ${index * 0.1}s`}
              >
                <ProjectCard
                  title={project.data.title}
                  description={project.data.description}
                  imageUrl={project.data.image}
                  projectUrl={project.data.projectUrl}
                  tecnologies={project.data.technologies}
                  icon={project.data.icon}
                  slug={project.data.slug || project.id.replace(".md", "")}
                  disableModal={true}
                />
              </div>
            ))
          }
        </div>

        <!-- No results message -->
        <div
          id="no-results"
          class="hidden text-center py-32"
        >
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-neutral-primary-soft dark:bg-card-surface-dark border border-Border dark:border-Border-dark mb-6">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="text-body dark:text-body-light"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
          </div>
          <p class="text-2xl font-bold text-Text-dark dark:text-white mb-2">
            Sin resultados
          </p>
          <p class="text-body dark:text-body-light">
            No se encontraron proyectos con esta tecnología
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Filter functionality - compatible with Astro View Transitions
  function initializeFilters() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const projectItems = document.querySelectorAll('.project-item');
    const noResults = document.getElementById('no-results');
    const visibleCountEl = document.getElementById('visible-count');
    const projectsGrid = document.getElementById('projects-grid');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');

        // Update active button
        filterButtons.forEach(btn => {
          btn.classList.remove('active', 'bg-Orange-vibrant', 'text-white', 'dark:bg-Orange-vibrant-dark');
          btn.classList.add('bg-neutral-primary-soft', 'dark:bg-card-surface-dark', 'text-Text-dark', 'dark:text-Text-light');
        });
        button.classList.add('active', 'bg-Orange-vibrant', 'text-white', 'dark:bg-Orange-vibrant-dark');
        button.classList.remove('bg-neutral-primary-soft', 'dark:bg-card-surface-dark', 'text-Text-dark', 'dark:text-Text-light');

        // Add fade animation class
        projectsGrid?.classList.add('filtering');

        // Filter projects with stagger animation
        let visibleCount = 0;
        let delay = 0;

        projectItems.forEach((item, index) => {
          const technologies = JSON.parse(item.getAttribute('data-technologies') || '[]');
          const shouldShow = filter === 'all' || technologies.includes(filter);

          // Reset animation
          (item as HTMLElement).style.animation = 'none';

          setTimeout(() => {
            if (shouldShow) {
              (item as HTMLElement).style.display = 'block';
              (item as HTMLElement).style.animation = `fadeInUp 0.5s ease-out ${delay}s both`;
              visibleCount++;
              delay += 0.05;
            } else {
              (item as HTMLElement).style.display = 'none';
            }
          }, 10);
        });

        // Update counter
        setTimeout(() => {
          if (visibleCountEl) {
            visibleCountEl.textContent = visibleCount.toString();
          }
          projectsGrid?.classList.remove('filtering');
        }, 100);

        // Show/hide no results message
        setTimeout(() => {
          if (visibleCount === 0) {
            noResults?.classList.remove('hidden');
          } else {
            noResults?.classList.add('hidden');
          }
        }, 200);
      });
    });
  }

  // Initialize on page load
  document.addEventListener('astro:page-load', initializeFilters);
</script>

<style>
  /* Filter buttons */
  .filter-btn {
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .filter-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
  }

  .filter-btn:active {
    transform: translateY(0);
  }

  /* Project items animations */
  .project-item {
    animation: fadeInUp 0.6s ease-out both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Grid filtering state */
  #projects-grid.filtering .project-item {
    transition: opacity 0.2s ease-out;
  }

  /* View Transitions */
  @view-transition {
    navigation: auto;
  }

  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.4s;
  }

  /* Atmospheric gradients */
  .absolute.inset-0 {
    animation: float 20s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-20px) scale(1.05);
    }
  }
</style>
