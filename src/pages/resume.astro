---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Resume | GuruSharan.dev"
  description="Resume — Guru Sharan, Full Stack Developer."
>
  <Header />

  <main
    class="min-h-screen bg-Background-light dark:bg-Background-dark relative overflow-hidden pt-24 md:pt-28 pb-16 px-4 sm:px-6"
  >
    <div
      class="absolute inset-0 bg-linear-to-tr from-Orange-vibrant/5 via-transparent to-Cyan-accent/5 dark:from-Orange-vibrant-dark/5 dark:to-Cyan-accent-dark/5 pointer-events-none"
    >
    </div>
    <div
      class="absolute top-1/4 left-0 w-1/3 h-1/3 bg-Orange-vibrant/3 dark:bg-Orange-vibrant-dark/3 blur-[120px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 max-w-5xl mx-auto w-full">
      <a
        href="/"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/90 dark:bg-black/90 backdrop-blur-sm text-Text-dark dark:text-Text-light hover:bg-Orange-vibrant hover:text-white dark:hover:bg-Orange-vibrant-dark transition-all duration-300 group shadow-lg border border-Border/50 dark:border-Border-dark/50 mb-8"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:-translate-x-1 transition-transform"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        <span class="text-sm font-medium">Home</span>
      </a>

      <h1
        class="text-3xl sm:text-4xl font-bold text-Text-dark dark:text-Text-light mb-6 text-center sm:text-left"
      >
        Resume
      </h1>

      <div
        class="rounded-xl overflow-hidden border border-Border dark:border-white/10 shadow-lg bg-neutral-primary-soft/30 dark:bg-Forenground-dark/20"
      >
        <div class="p-10 sm:p-12 text-center">
          <p class="text-body dark:text-body-light max-w-2xl mx-auto">
            Open my resume in a new tab for the best viewing experience.
          </p>

          <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/gurusharan_resume.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg bg-Orange-vibrant hover:bg-Orange-vibrant/90 dark:bg-Orange-vibrant-dark dark:hover:bg-Orange-vibrant-dark/90 text-white font-semibold transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 w-full sm:w-auto"
            >
              View Resume
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M15 3h6v6"></path>
                <path d="M10 14 21 3"></path>
                <path d="M21 14v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h6"></path>
              </svg>
            </a>

            <a
              href="/gurusharan_resume.pdf"
              download="gurusharan_resume.pdf"
              class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg bg-white/90 hover:bg-white dark:bg-black/70 dark:hover:bg-black/60 backdrop-blur-sm text-Text-dark dark:text-Text-light font-semibold transition-all duration-300 shadow-md hover:shadow-lg border border-Border/60 dark:border-Border-dark/60 w-full sm:w-auto"
            >
              Download
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
            </a>
          </div>

          <details class="mt-6 max-w-3xl mx-auto text-left">
            <summary class="cursor-pointer select-none text-sm text-body dark:text-body-light hover:text-Orange-vibrant dark:hover:text-Orange-vibrant-dark transition-colors">
              Preview (if supported)
            </summary>
            <div class="mt-4 rounded-xl overflow-hidden border border-Border dark:border-white/10 bg-Background-light/70 dark:bg-Background-dark/40">
              <embed
                src="/gurusharan_resume.pdf"
                type="application/pdf"
                class="w-full h-[55vh] md:h-[75vh] min-h-[320px]"
              />
              <p class="p-4 text-sm text-body dark:text-body-light">
                If the preview doesn’t load, use <strong>View Resume</strong> above.
              </p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
